Задача 3
-----------------------------------ЗАПРОС-----------------------------------
WITH CarAverages AS (
    SELECT 
        c.name AS car_name,
        c.class AS car_class,
        AVG(r.position) AS average_position,
        COUNT(r.race) AS race_count
    FROM Cars c
    INNER JOIN Results r ON c.name = r.car
    GROUP BY c.name, c.class
),
ClassAverages AS (
    SELECT 
        car_class,
        AVG(average_position) AS class_avg_position
    FROM CarAverages
    GROUP BY car_class
),
MinClassAvg AS (
    SELECT MIN(class_avg_position) AS min_avg
    FROM ClassAverages
),
TargetClasses AS (
    SELECT car_class
    FROM ClassAverages
    WHERE class_avg_position = (SELECT min_avg FROM MinClassAvg)
)
SELECT 
    ca.car_name,
    ca.car_class,
    ROUND(ca.average_position, 4) AS average_position,
    ca.race_count,
    cl.country AS car_country,
    (
        SELECT COUNT(DISTINCT race) 
        FROM Results r 
        INNER JOIN Cars c2 ON r.car = c2.name 
        WHERE c2.class = ca.car_class
    ) AS total_races
FROM CarAverages ca
INNER JOIN TargetClasses tc ON ca.car_class = tc.car_class
INNER JOIN Classes cl ON ca.car_class = cl.class
ORDER BY ca.average_position;
---------------------------------Результат запроса-------------------------
car_name	car_class	average_position	race_count	car_country	total_races	
Ferrari 488	Convertible	1.0000	1	Italy	1	
Ford Mustang	SportsCar	1.0000	1	USA	1	

Задача 4
---------------------------------Результат запроса-------------------------

WITH CarAverages AS (
    SELECT 
        c.name AS car_name,
        c.class AS car_class,
        AVG(r.position) AS average_position,
        COUNT(r.race) AS race_count
    FROM Cars c
    INNER JOIN Results r ON c.name = r.car
    GROUP BY c.name, c.class
),
ClassStats AS (
    SELECT 
        car_class,
        AVG(average_position) AS class_avg_position,
        COUNT(*) AS cars_in_class
    FROM CarAverages
    GROUP BY car_class
    HAVING COUNT(*) >= 2
)
SELECT 
    ca.car_name,
    ca.car_class,
    ROUND(ca.average_position, 4) AS average_position,
    ca.race_count,
    cl.country AS car_country
FROM CarAverages ca
INNER JOIN ClassStats cs ON ca.car_class = cs.car_class
INNER JOIN Classes cl ON ca.car_class = cl.class
WHERE ca.average_position < cs.class_avg_position
ORDER BY ca.car_class, ca.average_position;

---------------------------------Результат запроса-------------------------
car_name	car_class	average_position	race_count	car_country	
BMW 3 Series	Sedan	3.0000	1	Germany	
Toyota RAV4	SUV	2.0000	1	Japan	

